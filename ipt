using System;
using System.Collections.Generic;

namespace IntegrativeProgrammingActivity
{
    // --- 1. ABSTRACT CLASS (Requirement: Classes for mathematical computations) ---
    public abstract class AttendanceMath
    {
        public abstract double ComputeHours(DateTime timeIn, DateTime timeOut);
    }

    // --- 2. CLASS FOR DATA (Requirement: Encapsulation) ---
    public class AttendanceLog
    {
        public string EmployeeNumber { get; set; }
        public string EmployeeName { get; set; }
        public string Location { get; set; }
        public DateTime TimeIn { get; set; }
        public DateTime? TimeOut { get; set; }
        public double TotalHours { get; set; }
        public string Note { get; set; }
    }

    // --- 3. MAIN SYSTEM (Requirement: Inheritance) ---
    public class TimeTrackingSystem : AttendanceMath
    {
        // Requirement: Dictionary named "Employee Timein-TimeOut Record"
        private Dictionary<string, AttendanceLog> EmployeeTimeinTimeOutRecord = new Dictionary<string, AttendanceLog>();

        // Mock Database para sa pangalan ng empleyado
        private Dictionary<string, string> EmployeeDatabase = new Dictionary<string, string>
        {
            { "1010101", "Johnny" },
            { "1010102", "Alwys Smith" }
        };

        // Implementation ng Abstract Method
        public override double ComputeHours(DateTime timeIn, DateTime timeOut)
        {
            TimeSpan span = timeOut - timeIn;
            return Math.Round(span.TotalHours, 2);
        }

        public void RunSystem()
        {
            // INPUT SECTION
            Console.WriteLine("Employee Number:");
            string empNum = Console.ReadLine();

            if (!EmployeeDatabase.ContainsKey(empNum))
            {
                Console.WriteLine("Employee not found!");
                return;
            }

            Console.WriteLine("Which office are you located?");
            string location = Console.ReadLine(); // Accept: Philippines, United States, India

            // TIMEZONE PROCESSING
            DateTime officeTime = GetTimeByLocation(location);
            if (officeTime == DateTime.MinValue) return;

            // DISPLAY OUTPUT (Sakto sa screenshot mo)
            Console.WriteLine("\nYou clocked in at:");
            Console.WriteLine($"Date:{officeTime:MM/dd/yy}");
            Console.WriteLine($"Time: {officeTime:hh:mm:ss tt}");

            // SAVING TO DICTIONARY
            AttendanceLog newLog = new AttendanceLog
            {
                EmployeeNumber = empNum,
                EmployeeName = EmployeeDatabase[empNum],
                Location = location,
                TimeIn = officeTime
            };
            EmployeeTimeinTimeOutRecord[empNum] = newLog;

            // LOG DISPLAY
            Console.WriteLine("\nEmployee Log:");
            Console.WriteLine($"Name:{newLog.EmployeeName}");
            Console.WriteLine($"Location:{newLog.Location}");
            Console.WriteLine($"Time-In:{newLog.TimeIn:MM/dd/yy hh:mm:ss tt}");

            // --- OPTIONAL: SIMULATION NG TIME-OUT PARA SA NOTES ---
            // Tinawag natin ang computation logic dito para maipakita ang "Note" requirement
            SimulateTimeOut(empNum);
        }

        private DateTime GetTimeByLocation(string location)
        {
            try
            {
                string tzId = location.ToLower() switch
                {
                    "philippines" => "Singapore Standard Time",
                    "united states" => "Eastern Standard Time",
                    "india" => "India Standard Time",
                    _ => ""
                };

                if (tzId == "") 
                {
                    Console.WriteLine("Invalid Location!");
                    return DateTime.MinValue;
                }

                TimeZoneInfo tz = TimeZoneInfo.FindSystemTimeZoneById(tzId);
                return TimeZoneInfo.ConvertTime(DateTime.Now, tz);
            }
            catch
            {
                Console.WriteLine("Timezone Error.");
                return DateTime.MinValue;
            }
        }

        private void SimulateTimeOut(string empNum)
        {
            var log = EmployeeTimeinTimeOutRecord[empNum];
            // Halimbawa: Nag-time out matapos ang 11 hours (Overtime)
            DateTime simulatedTimeOut = log.TimeIn.AddHours(11); 
            
            log.TimeOut = simulatedTimeOut;
            log.TotalHours = ComputeHours(log.TimeIn, simulatedTimeOut);

            // LOGIC PARA SA NOTES (Requirement)
            if (log.TotalHours == 9)
            {
                log.Note = "";
            }
            else if (log.TotalHours < 9)
            {
                double diff = 9 - log.TotalHours;
                log.Note = $"Early Out. Hours left: {diff} hours";
            }
            else
            {
                double extended = log.TotalHours - 9;
                log.Note = $"Overtime. Hours extended: {extended} hours";
            }

            Console.WriteLine($"\n--- Attendance Summary ---");
            Console.WriteLine($"Total Hours: {log.TotalHours}");
            Console.WriteLine($"Note: {log.Note}");
        }
    }

    class Program
    {
        static void Main(string[] args)
        {
            TimeTrackingSystem system = new TimeTrackingSystem();
            system.RunSystem();

            Console.WriteLine("\nPress any key to exit...");
            Console.ReadKey();
        }
    }
}
